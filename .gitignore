# =============================================================================
# .gitignore
# Marginalia — Your literary assistant
# =============================================================================

# --- Artifacts (stored in HF Dataset, not in repo) ---------------------------
*.pkl
*.csv

# --- Notebooks (development only) --------------------------------------------
*.ipynb
.ipynb_checkpoints/

# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# --- Environment -------------------------------------------------------------
.env
.venv/
venv/
env/

# --- Secrets (never commit these) --------------------------------------------
secrets.toml
.streamlit/secrets.toml

# --- OS ----------------------------------------------------------------------
.DS_Store
Thumbs.db

# --- Logs --------------------------------------------------------------------
*.log
